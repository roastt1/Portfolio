{
  "version": "1.0",
  "skills": {
    "skill-developer": {
      "type": "domain",
      "enforcement": "suggest",
      "priority": "medium",
      "promptTriggers": {
        "keywords": [
          "create skill",
          "new skill",
          "skill trigger",
          "add skill",
          "skill-rules",
          "skill system"
        ],
        "intentPatterns": [
          "(create|add|make|build).*(skill)",
          "skill.*(system|activation|trigger)"
        ]
      }
    },
    "nextjs-guidelines": {
      "type": "guardrail",
      "enforcement": "suggest",
      "priority": "high",
      "promptTriggers": {
        "keywords": [
          "component",
          "page",
          "layout",
          "section",
          "tailwind",
          "animation",
          "framer",
          "gsap",
          "dark mode",
          "darkmode",
          "responsive",
          "mobile",
          "header",
          "footer",
          "hero",
          "about",
          "projects",
          "skills",
          "contact",
          "next.js",
          "nextjs",
          "react"
        ],
        "intentPatterns": [
          "(create|add|make|build).*(component|page|section|layout)",
          "(add|implement|fix).*(animation|effect|transition|scroll)",
          "(fix|update|modify|change).*(style|css|design|layout|ui|ux)",
          "(add|implement).*(dark|light).*(mode|theme)"
        ]
      },
      "fileTriggers": {
        "pathPatterns": [
          "app/**/*.tsx",
          "app/**/*.ts",
          "app/globals.css",
          "tailwind.config.js"
        ]
      }
    }
  }
}
